import requests
username = input("Enter user name:")
url = f"https://api.github.com/users/{username}"
def save_file(data):
    with open("/Users/kavi/Desktop/github_user.txt","a") as f:
        f.write("--\n User Info--\n")
        f.write(f"Name: {data.get('login')}\n")
        f.write(f"Repos: {data.get('public_repos')}\n")
        f.write(f"Followers: {data.get('followers')}\n")
try:
  response = requests.get(url,timeout=5)
  
  if response.status_code==200 :
    data = response.json()
    print("Name:",data.get('login'))
    print("Repos:",data.get('public_repos'))
    print("Followers:",data.get('followers'))
    save_file(data)
  elif response.status_code==404:
    print("User not found")
  else:
    print(f"Error:{response.status_code}")
except requests.ConnectionError:
    print("Connection error")
except requests.Timeout:
    print("Request timed out")
except requests.RequestException as e:
    print("Request error",e)